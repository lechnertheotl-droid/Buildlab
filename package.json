{
  "name": "buildlab",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Interaktive, projektbasierte Lern-App für Maschinenbau (pseudo-3D).",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify:content": "node tools/verify/index.mjs",
    "test": "vitest run",
    "verify": "pnpm lint && pnpm typecheck && pnpm verify:content && pnpm test && pnpm build"
  },
  "dependencies": {
    "@buildlab/cad": "workspace:*",
    "@buildlab/engine": "workspace:*",
    "@buildlab/ui": "workspace:*",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/hanken-grotesk": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "idb": "^8.0.3",
    "mathjs": "^13.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.17.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "ajv": "^8.17.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "globals": "^15.13.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.18.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
